# RotaLive Backend — Environment Variables
# Copy this file to .env and fill in the values

# Security
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite+aiosqlite:///./rotalive.db

# WhatsApp API (Evolution API or official Meta WABA)
WHATSAPP_API_URL=https://your-whatsapp-api-instance.com
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# App
APP_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT_NOTIFY=10/minute
